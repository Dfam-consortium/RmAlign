// conf/profiles.config
// Executor profiles.  Resource specs live in conf/base.config.

profiles {

    // Default: run all processes on the local machine.
    standard {
        process.executor = 'local'
        executor {
          cpus = 32
        }        
    }

    // SLURM profile for the local rmcluster partition.
    // --cpus / params.threads controls threads inside each align job;
    // base.config sets cpus = params.threads so SLURM allocates the right
    // number of cores per job automatically.
    rmcluster {
        process.executor = 'slurm'
        process.queue    = 'rmcluster'
        executor {
            queueSize       = 500
            submitRateLimit = '200/1min'
        }
    }
}
